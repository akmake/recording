<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!-- rgba(255,255,255,0.72) → #B8FFFFFF, but on white bg this looks white.
         Use near-white with the border to match the glass-panel effect. -->
